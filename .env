# Database Setup
DATABASE_URL="postgres://inventiv_user:inventiv_password@localhost:5432/inventiv_agents"
REDIS_URL="redis://localhost:6379"

# Auth Setup
JWT_SECRET="PLEASE_CHANGE_ME_IN_PRODUCTION_0123456789ABCDEF"
AUTH_EXPIRY_HOURS=24

# OAuth Providers (Placeholders for Milestone 1)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Internationalization
DEFAULT_LOCALE="en_US"
SUPPORTED_LOCALES="en_US,fr_FR,ar_AR"

# Logging Level
RUST_LOG="inventivagents=debug,tower_http=debug,axum::rejection=trace"
