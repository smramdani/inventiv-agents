# Copy to ".env" and adjust values. Docker Compose reads this file for variable substitution.
# Never commit ".env" with production secrets.

# Optional: directory containing the `docker` binary when not on PATH (macOS Docker.app path).
# INVENTIV_DOCKER_BIN=/Applications/Docker.app/Contents/Resources/bin

# -----------------------------------------------------------------------------
# PostgreSQL (Docker Compose service "db")
# Superuser used for schema migrations and admin tasks (psql, backups).
# -----------------------------------------------------------------------------
POSTGRES_USER=inventiv_user
# Must match docker-compose default unless you override both there and in your local .env
POSTGRES_PASSWORD=inventiv_password
POSTGRES_DB=inventiv_agents
POSTGRES_PORT=5432
# Host used by ./scripts/db/apply-migrations.sh when not using Docker (default 127.0.0.1).
# POSTGRES_HOST=127.0.0.1

# Optional: full URL for host-only migrations (superuser). If unset, POSTGRES_* + POSTGRES_HOST are used.
# MIGRATE_DATABASE_URL=postgres://inventiv_user:inventiv_password@127.0.0.1:5432/inventiv_agents

# Optional: published Redis port (compose)
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Application database URL (RLS application role from backend/migrations/001)
# Local host run: use 127.0.0.1 and the SAME port as POSTGRES_PORT above.
# API inside Compose: host would be `db`, port `5432` (container port, not POSTGRES_PORT).
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://inventiv_app:inventiv_app_password@127.0.0.1:5432/inventiv_agents

# Optional: override integration-test DB URL only (defaults: same host/db as DATABASE_URL but user inventiv_app).
# INVENTIV_TEST_DATABASE_URL=postgres://inventiv_app:...@127.0.0.1:5432/inventiv_agents

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
JWT_SECRET=dev_jwt_secret_change_me_min_32_chars_recommended_xxxx

# Comma-separated browser origins allowed by the API CORS layer (M5 cockpit).
# Defaults in code: http://127.0.0.1:5173,http://localhost:5173
# INVENTIV_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# -----------------------------------------------------------------------------
# Staging / production (e.g. Scaleway Managed PostgreSQL)
# -----------------------------------------------------------------------------
# Use the connection string from the console (often TLS required):
# DATABASE_URL=postgres://inventiv_app:<password>@<host>:5432/inventiv_agents?sslmode=require
#
# Operational checklist:
# - Run the same ordered SQL migrations as local (001 … 004) using a superuser
#   or migration role that can CREATE EXTENSION / CREATE ROLE as required.
# - Restrict network access (private VPC / IP allowlist); rotate passwords via secret manager.
# - Point backups and monitoring at the managed instance SLA.
